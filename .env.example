# ─────────────────────────────────────────────────────────────────────────────
# Hyderabad Jobs API — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Adzuna API ────────────────────────────────────────────────────────────────
# Register free at: https://developer.adzuna.com/
APP_ID=your_adzuna_app_id
APP_KEY=your_adzuna_app_key

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# 1. Create bot via @BotFather on Telegram → get BOT_TOKEN
# 2. Get CHAT_ID: send a message to your bot/channel, then call:
#    https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id_or_channel

# ── Database ──────────────────────────────────────────────────────────────────
# Local path where jobs.db will be stored.
# On Render free tier use /tmp (ephemeral but fine — jobs re-fetch automatically)
DB_DIR=.

# ── Tuning (optional, safe defaults are set in config.py) ────────────────────
# FETCH_COOLDOWN_SECONDS=3600   # Minimum seconds between Adzuna API calls
# MAX_STORED_JOBS=500           # SQLite row cap — older rows are deleted
# TELEGRAM_MAX_AGE_HOURS=48     # Only post jobs newer than this many hours
